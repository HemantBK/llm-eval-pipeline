# === LLM Eval Pipeline Configuration ===
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://eval:eval_dev@postgres:5432/eval_pipeline

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API Auth ---
API_KEY=your-secret-api-key-here

# --- LLM Provider Keys ---
# Gemini (required): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (optional): https://platform.openai.com
OPENAI_API_KEY=

# Anthropic (optional): https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- vLLM / Ollama ---
VLLM_BASE_URL=http://vllm:8000/v1
# Use host.docker.internal when Ollama runs on host, ollama:11434 if using docker-compose.override
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Judge Configuration ---
JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-2.0-flash

# --- Rate Limits (RPM) ---
GEMINI_RPM=15
OPENAI_RPM=60
VLLM_RPM=1000

# --- Cache ---
CACHE_TTL_SECONDS=86400

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
